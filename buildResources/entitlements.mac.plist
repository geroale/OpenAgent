<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the OpenAgent server + CLI PyInstaller
  onefile binaries. These three are the standard PyInstaller set:

    allow-jit                          — Python's ctypes/cffi JIT paths
    allow-unsigned-executable-memory   — PyInstaller's runtime loader mprotects
                                         pages as exec that aren't signed
    disable-library-validation         — .so files extracted to $TMPDIR/_MEI_*
                                         aren't signed with our cert; validation
                                         would abort load without this

  No camera / microphone / file-access entitlements — the headless server
  doesn't need them. The Desktop app has a broader plist for media access.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
