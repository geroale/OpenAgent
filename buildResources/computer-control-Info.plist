<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the ``openagent-computer-control.app`` wrapper.

  The Rust binary that provides computer-control is a CLI tool, but
  macOS TCC (Transparency, Consent, and Control) does not play well
  with bare CLI tools:

    1. CLI tools spawned by launchd-managed parents (``openagent serve``
       running as a launchd agent) cannot show TCC permission dialogs.
       ``AXIsProcessTrustedWithOptions(kAXTrustedCheckOptionPrompt=true)``
       silently returns false with no user-visible prompt.
    2. Even when a prompt is forced (e.g. by invoking via Terminal),
       CLI tools without ``CFBundleIdentifier`` don't get persistent
       rows in System Settings → Privacy & Security → Accessibility.
       The prompt fires, the user clicks "Open System Settings", and
       the pane shows no toggle.

  Wrapping the binary in a minimal ``.app`` bundle with this Info.plist
  fixes both: macOS recognises the process as a full app, shows the
  prompt properly, and lists it in the Accessibility pane with a stable
  reverse-DNS identifier so grants persist across updates.

  ``LSBackgroundOnly=true`` keeps the app invisible (no Dock icon, no
  menu bar entry) since it's purely a MCP stdio helper.

  The Usage-Description strings below are what macOS displays in the
  permission dialog ("<app> wants to <thing> because <reason>"). Each
  TCC-gated capability needs its own *UsageDescription key or the dialog
  text falls back to a generic phrase.
-->
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.openagent.computer-control</string>
    <key>CFBundleExecutable</key>
    <string>openagent-computer-control</string>
    <key>CFBundleName</key>
    <string>OpenAgent Computer Control</string>
    <key>CFBundleDisplayName</key>
    <string>OpenAgent Computer Control</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>LSBackgroundOnly</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>10.15</string>
    <key>NSAccessibilityUsageDescription</key>
    <string>OpenAgent needs Accessibility to simulate keyboard input and mouse clicks when the agent automates GUI applications on your behalf.</string>
    <key>NSScreenCaptureDescription</key>
    <string>OpenAgent needs Screen Recording to capture screenshots so the agent can see what's on your screen when you ask it to.</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>OpenAgent may send Apple Events to control other applications when you ask it to automate them.</string>
</dict>
</plist>
