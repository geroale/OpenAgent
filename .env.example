# OpenAgent — consolidated environment variables
#
# Copy this file to `.env` and fill in the values you need, OR set them in
# your shell / GitHub Actions secrets. Nothing auto-loads this file at
# runtime — OpenAgent reads API keys from `openagent.yaml` (with `${VAR}`
# expansion from your environment). This file exists so humans and CI can
# see every knob in one place.
#
# Variables are grouped by concern:
#
#   [CI / release]      set as GitHub Actions repository secrets
#   [dev / runtime]     set in your shell or load via your IDE / direnv
#   [channel tokens]    forwarded into the messaging MCP subprocess
#
# Never commit a real `.env` — it's already in .gitignore.


# ─── [CI / release] macOS code-signing + notarization ──────────────────
# Used by .github/workflows/release.yml for both the Desktop app
# (electron-builder) and the Server/CLI PyInstaller binaries
# (scripts/sign-notarize-macos.sh). Same credentials — one setup, both
# flows signed + notarized.
#
# Set these as GitHub Actions secrets on the repository; they don't need
# to be on developer workstations.

# Base64-encoded Developer ID .p12 certificate.
#   $ base64 -i cert.p12 | pbcopy
CSC_LINK=

# Password that unlocks the .p12.
CSC_KEY_PASSWORD=

# Apple Developer account email (the one that owns the cert).
APPLE_ID=

# App-specific password — generate at https://appleid.apple.com
# (don't use your main account password; that won't work with notarytool).
APPLE_APP_SPECIFIC_PASSWORD=

# Apple Developer Team ID (10-char alphanumeric string).
# Find it at https://developer.apple.com/account (top-right).
APPLE_TEAM_ID=


# ─── [dev / runtime] LLM provider API keys ────────────────────────────
# OpenAgent's `openagent.yaml` references these with `${VAR}` substitution,
# e.g. `api_key: ${OPENAI_API_KEY}`. You only need the ones for providers
# you actually use — leave the rest unset.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
ZAI_API_KEY=
TAVILY_API_KEY=


# ─── [channel tokens] messaging platforms ─────────────────────────────
# Forwarded into the `messaging` MCP subprocess (see
# openagent/mcp/pool.py — _MESSAGING_TOKEN_ENV_VARS). Only platforms with
# a token configured show up as tools to the LLM.

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Discord application bot token
DISCORD_BOT_TOKEN=

# WhatsApp via Green API (https://green-api.com)
GREEN_API_ID=
GREEN_API_TOKEN=


# ─── [dev / runtime] gateway auth ─────────────────────────────────────

# Shared-secret token required on WebSocket connections. When unset the
# gateway runs without auth — fine for localhost, dangerous for anything
# reachable from the network.
OPENAGENT_WS_TOKEN=


# ─── [dev / runtime] optional ─────────────────────────────────────────

# GitHub token for elevated auto-update API rate-limit.
# The updater works anonymously for most users; set this only if you hit
# the 60-req/hr anonymous limit.
GITHUB_TOKEN=
